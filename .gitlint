[general]
ignore=body-is-missing,body-min-length
ignore-merge-commits=true
ignore-revert-commits=true

[title-max-length]
line-length=72

[body-max-line-length]
line-length=100

[title-match-regex]
regex=^(feat|fix|docs|style|refactor|test|chore|build|ci|perf|revert)(\([a-z0-9._/-]+\))?!?: [^ ].+[^ .]$

[title-min-length]
min-length=10

[title-must-not-contain-word]
words=wip
